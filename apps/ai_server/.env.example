# AI 서버 환경변수 파일
OPENROUTER_API_KEY=

# NVIDIA NIM API용 키
NVIDIA_API_KEY=""
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_CHAT_MODEL=
NVIDIA_ANALYZE_MODEL=

# 채팅 지연 시간 최적화: 요청마다 전송할 최근 대화량 제한
CHAT_HISTORY_MAX_TURNS=12
CHAT_HISTORY_MAX_CHARS=6000
CHAT_SUMMARY_MAX_CHARS=1200

# Self-hosted NVIDIA NIM 컨테이너에서만 적용됩니다.
# Hosted API(integrate.api.nvidia.com)는 AI 서버 .env로 이 값을 켤 수 없습니다.
NIM_ENABLE_KV_CACHE_REUSE=1

# Supabase 연결
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
DATABASE_URL=""

# Supabase Storage 버킷 이름
SUPABASE_REPORT_BUCKET=sally-storage

# 백엔드 callback api 호출 헤더
INTERNAL_SECRET_KEY=""
