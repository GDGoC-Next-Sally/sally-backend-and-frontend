generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model attends {
  student_id String   @db.Uuid
  session_id Int
  sessions   sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@id([student_id, session_id])
}

model chat_messages {
  id          Int         @id @default(autoincrement())
  dialog_id   Int
  sender_type sender_type
  content     String
  is_global   Boolean     @default(false)
  created_at  DateTime    @default(now()) @db.Timestamptz(6)
  dialogs     dialogs     @relation(fields: [dialog_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model class_reports {
  id         Int      @id @default(autoincrement())
  class_id   Int      @unique
  content    Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  classes    classes  @relation(fields: [class_id], references: [id], onDelete: Cascade)
}

model classes {
  id            Int            @id @default(autoincrement())
  teacher_id    String         @db.Uuid
  status        class_status   @default(ACTIVE)
  grade         Int?           @default(1)
  homeroom      String?        @db.VarChar(50)
  subject       String         @db.VarChar(100)
  explanation   String?
  theme         String?        @db.VarChar(50)
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  completed_at  DateTime?      @db.Timestamptz(6)
  invite_code   String         @unique @db.VarChar(10)
  registerable  Boolean        @default(true)
  schedule      Json?
  class_reports class_reports?
  users         users          @relation(fields: [teacher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sessions      sessions[]
  takes         takes[]
}

model dialogs {
  id                 Int              @id @default(autoincrement())
  session_id         Int
  student_id         String           @db.Uuid
  status             Boolean          @default(true)
  real_time_analysis Json?
  is_analyzed        Boolean          @default(false)
  chat_messages      chat_messages[]
  sessions           sessions         @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users            @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  student_reports    student_reports?

  @@unique([session_id, student_id])
}

model session_reports {
  id         Int      @id @default(autoincrement())
  session_id Int      @unique
  content    Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  sessions   sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
}

model sessions {
  id                 Int                  @id @default(autoincrement())
  class_id           Int
  teacher_id         String               @db.Uuid
  session_name       String               @db.VarChar(255)
  status             session_status       @default(PLANNING)
  explanation        String?
  started_at         DateTime?            @db.Timestamptz(6)
  finished_at        DateTime?            @db.Timestamptz(6)
  period             Int?
  scheduled_end      DateTime?            @db.Timestamptz(6)
  scheduled_start    DateTime?            @db.Timestamptz(6)
  scheduled_date     DateTime?            @db.Date
  objective          String?
  session_prompt     String?
  attends            attends[]
  dialogs            dialogs[]
  session_reports    session_reports?
  classes            classes              @relation(fields: [class_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users                @relation(fields: [teacher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student_reports    student_reports[]
  supplementary_data supplementary_data[]
}

model student_reports {
  id         Int      @id @default(autoincrement())
  student_id String   @db.Uuid
  session_id Int
  dialog_id  Int      @unique
  content    Json?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  dialogs    dialogs  @relation(fields: [dialog_id], references: [id], onDelete: Cascade)
  sessions   sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)
  users      users    @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model supplementary_data {
  id         Int      @id @default(autoincrement())
  session_id Int
  file_name  String   @db.VarChar(255)
  file_url   String
  file_type  String?  @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  sessions   sessions @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model takes {
  student_id String  @db.Uuid
  class_id   Int
  classes    classes @relation(fields: [class_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users   @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@id([student_id, class_id])
}

model textbooks {
  id             Int            @id @default(autoincrement())
  subject        String         @db.VarChar(100)
  publisher      String?        @db.VarChar(100)
  year_published Int?
  unit_prompts   unit_prompts[]
}

model unit_prompts {
  id          Int        @id @default(autoincrement())
  textbook_id Int?
  unit_number Int?
  creator_id  String     @db.Uuid
  objective   String
  prompt      String
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  textbooks   textbooks? @relation(fields: [textbook_id], references: [id], onUpdate: NoAction)
  users       users      @relation(fields: [creator_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String            @db.VarChar(100)
  email           String            @unique @db.VarChar(255)
  role            user_role         @default(STUDENT)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  attends         attends[]
  classes         classes[]
  dialogs         dialogs[]
  sessions        sessions[]
  student_reports student_reports[]
  takes           takes[]
  unit_prompts    unit_prompts[]
}

enum class_status {
  PLANNING
  ACTIVE
  COMPLETED
}

enum sender_type {
  STUDENT
  AI
  TEACHER
}

enum session_status {
  PLANNING
  ACTIVE
  FINISHED
}

enum user_role {
  STUDENT
  TEACHER
  ADMIN
}
